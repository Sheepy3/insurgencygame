[sub_resource type="Shader" id="Shader_shadow_catcher"]
code = "shader_type spatial;
render_mode cull_disabled;

uniform vec3 shadow_color: source_color = vec3(0.0);
uniform float shadow_opacity: hint_range(0.0, 1.0) = 0.7;
uniform float shadow_max_opacity: hint_range(0.0, 1.0) = 0.8;
uniform float shadow_threshold: hint_range(0.01, 1.0) = 0.25;

void fragment() {
	ALBEDO = shadow_color;
	ALPHA = 0.0;
}

void light() {
	DIFFUSE_LIGHT = ALBEDO;
	// ATTENUATION also contains OmniLight distance falloff. Only values near
	// zero are treated as shadow so the lit plane remains fully transparent.
	float shadow = 1.0 - smoothstep(0.0, shadow_threshold, ATTENUATION);
	ALPHA = min(ALPHA + shadow_opacity * shadow, shadow_max_opacity);
}
"

